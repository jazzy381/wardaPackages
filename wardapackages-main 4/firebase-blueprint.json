{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "btnText": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "subtitle", "image"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global application setting.",
      "type": "object",
      "properties": {
        "value": { "type": "string" }
      },
      "required": ["value"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["customerName", "address", "phone", "total", "status", "items"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products shown on landing page."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Store settings (e.g., logo, headings)."
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "List of administrators."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders."
    }
  }
}
